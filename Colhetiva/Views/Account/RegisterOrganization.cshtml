@model Colhetiva.DTOs.OrganizationCreateDto
@{
    ViewData["Title"] = "Cadastrar Organização";
}

@section Styles {
    <link rel="stylesheet" href="~/css/login.css" />
}

<div id="s2" class="screen active">
  <div class="auth-wrap">
    <div class="auth-side">
      <div>
        <div class="auth-side-logo">Colhetiva</span></div>
        <p class="auth-side-tagline">Conectando cidadãos a espaços de cultivo urbano para uma cidade mais verde e colaborativa.</p>
      </div>
      <div class="auth-side-footer">Universidade de Caxias do Sul · Projeto Temático III</div>
    </div>

    <div class="auth-form">
      <div class="form-title">Cadastrar Organização</div>

      <form asp-action="RegisterOrganization" method="post" novalidate>
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="text-danger" style="margin-bottom:12px;"></div>

        <div class="field-row">
          <div class="field">
            <label asp-for="Nome"></label>
            <input asp-for="Nome" class="login-input" placeholder="Ex.: Secretaria de Meio Ambiente" />
            <span asp-validation-for="Nome" class="text-danger"></span>
          </div>
          <div class="field">
            <label asp-for="TipoOrganizacao">Tipo</label>
            <select asp-for="TipoOrganizacao" class="login-input">
              <option value="">Selecione...</option>
              <option value="Prefeitura">Prefeitura</option>
              <option value="ONG">ONG</option>
              <option value="Associacao">Associação de Moradores</option>
              <option value="Instituicao">Instituição de Ensino</option>
              <option value="Empresa">Empresa</option>
              <option value="Outro">Outro</option>
            </select>
            <span asp-validation-for="TipoOrganizacao" class="text-danger"></span>
          </div>
        </div>

        <div class="field">
          <label asp-for="Email"></label>
          <input asp-for="Email" class="login-input" placeholder="contato@exemplo.com" />
          <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="field-row">
          <div class="field">
            <label asp-for="Password"></label>
            <input asp-for="Password" type="password" class="login-input" placeholder="Mínimo 8 caracteres" />
            <span asp-validation-for="Password" class="text-danger"></span>
          </div>
          <div class="field">
            <label asp-for="ConfirmPassword"></label>
            <input asp-for="ConfirmPassword" type="password" class="login-input" placeholder="Repita a senha" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
          </div>
        </div>

        <div class="field">
          <label asp-for="Telefone"></label>
          <input asp-for="Telefone" id="Telefone" class="login-input" placeholder="(00) 00000-0000" />
          <span asp-validation-for="Telefone" class="text-danger"></span>
        </div>

        <hr style="margin:16px 0;border-color:var(--gray-200);" />

        <div class="form-title" style="font-size:16px;margin-bottom:12px;">Endereço da Organização</div>

        <div class="field-row">
          <div class="field">
            <label for="Endereco.Cep">CEP</label>
            <input name="Endereco.Cep" class="login-input" placeholder="00000-000" value="@(ViewData.Model?.Endereco?.Cep ?? "")" />
          </div>
          <div class="field">
            <label for="Endereco.CidadeId">Cidade</label>
            <input type="hidden" name="Endereco.CidadeId" id="CidadeId_Hidden" value="@(Model?.Endereco?.CidadeId.ToString() ?? "")" />
            <select id="CidadeId_Select" class="login-input" onchange="document.getElementById('CidadeId_Hidden').value = this.value">
                <option value="">Selecione...</option>
                @foreach (var cidade in ViewBag.Cidades)
                {
                    <option value="@cidade.Value" selected="@(Model?.Endereco?.CidadeId.ToString() == cidade.Value ? "selected" : null)">@cidade.Text</option>
                }
            </select>
          </div>
        </div>

        <div class="field">
          <label for="Endereco.Rua">Rua</label>
            <input name="Endereco.Rua" class="login-input" placeholder="Rua Exemplo, Av. ..." value="@(ViewData.Model?.Endereco?.Rua ?? "")" />
        </div>

        <div class="field-row">
          <div class="field">
            <label for="Endereco.Bairro">Bairro</label>
            <input name="Endereco.Bairro" class="login-input" placeholder="Bairro" value="@(ViewData.Model?.Endereco?.Bairro ?? "")" />
          </div>
          <div class="field">
            <label for="Endereco.Numero">Número</label>
            <input name="Endereco.Numero" class="login-input" placeholder="Número" value="@(ViewData.Model?.Endereco?.Numero ?? "")" />
          </div>
        </div>

        <div class="field">
          <label for="Endereco.Complemento">Complemento</label>
          <input name="Endereco.Complemento" class="login-input" placeholder="Complemento" value="@(ViewData.Model?.Endereco?.Complemento ?? "")" />
        </div>

        <button type="submit" class="btn-primary" style="margin-top:8px;">Cadastrar Organização</button>
        <p class="auth-link">Já tem conta? <a asp-controller="Account" asp-action="Login">Faça login</a></p>
      </form>
    </div>
  </div>
</div>