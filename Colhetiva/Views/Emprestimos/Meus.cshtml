@model List<Colhetiva.Core.Entities.Emprestimo>
@using Colhetiva.Core.Enums
@{
    ViewData["Title"] = "Meus Empréstimos";
}

<h2>Meus Empréstimos</h2>

@if (TempData["MensagemSucesso"] != null)
{
    <div class="alert alert-success">@TempData["MensagemSucesso"]</div>
}
@if (TempData["MensagemInfo"] != null)
{
    <div class="alert alert-info">@TempData["MensagemInfo"]</div>
}
@if (TempData["MensagemErro"] != null)
{
    <div class="alert alert-danger">@TempData["MensagemErro"]</div>
}

@if (Model == null || !Model.Any())
{
    <div class="alert alert-secondary">Vocę năo possui empréstimos registrados.</div>
}
else
{
    <table class="table table-sm">
        <thead>
            <tr>
                <th>Horta</th>
                <th>Ferramenta</th>
                <th>Retirada</th>
                <th>Devoluçăo</th>
                <th style="width:160px;text-align:center;">Status / Açőes</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model)
            {
                <tr>
                    <td>@e.Ferramenta?.Horta?.Nome</td>
                    <td>@e.Ferramenta?.Nome</td>
                    <td>@e.DataRetirada.ToLocalTime().ToString("g")</td>
                    <td>@(e.DataDevolucao.HasValue ? e.DataDevolucao.Value.ToLocalTime().ToString("g") : "-")</td>
                    <td class="text-center">
                        @if (e.Status == StatusEmprestimo.Pendente)
                        {
                            <span class="badge bg-warning text-dark">Pendente</span>
                        }
                        else if (e.Status == StatusEmprestimo.Aprovado)
                        {
                            @if (e.DataDevolucao == null)
                            {
                                <form asp-action="Devolver" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="emprestimoId" value="@e.Id" />
                                    <input type="hidden" name="hortaId" value="@(e.Ferramenta?.Horta?.Id ?? Guid.Empty)" />
                                    <button type="submit" class="btn btn-outline-success btn-sm">Devolver</button>
                                </form>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Devolvido</span>
                            }
                        }
                        else if (e.Status == StatusEmprestimo.Recusado)
                        {
                            <span class="badge bg-danger">Recusado</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="mt-3">
    <a class="btn btn-link" href="@Url.Action("Index", "Home")">Voltar</a>
</div>