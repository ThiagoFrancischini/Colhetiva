@model HortaCadastroViewModel
@{
    ViewData["Title"] = "Nova horta";
}

<div class="ch-page-header mb-4">
    <div class="ch-page-header__left">
        <div>
            <h1 class="ch-page-header__title">Nova horta</h1>
            <p class="ch-page-header__sub">Preencha os dados para cadastrar uma nova horta comunitária</p>
        </div>
    </div>
    <a asp-action="Index" class="btn-back" style="border-color:rgba(255,255,255,.35);color:rgba(255,255,255,.9);background:transparent;">
        ← Voltar
    </a>
</div>


<form asp-action="Create" method="post" id="formHorta">

    <div class="panel mb-4">
        <div class="panel-header">
            <span class="panel-title">Dados da horta</span>
        </div>
        <div class="panel-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Nome" class="field-label"></label>
                    <input asp-for="Nome" class="form-control" />
                    <span asp-validation-for="Nome" class="hint-text text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="UsuarioId" class="field-label"></label>
                    <select asp-for="UsuarioId" asp-items="ViewBag.Usuarios" class="form-select js-select2-responsavel">
                        <option value="">Nenhum (a organização é a responsável)</option>
                    </select>
                    <span class="hint-text">Deixe em branco para a própria organização ficar responsável pela horta.</span>
                    <span asp-validation-for="UsuarioId" class="hint-text text-danger"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Regras" class="field-label"></label>
                    <textarea asp-for="Regras" class="form-control" rows="4"
                              placeholder="Descreva as regras e orientações para os participantes..."></textarea>
                    <span class="hint-text">Visível publicamente na página da horta.</span>
                </div>
            </div>
        </div>
    </div>

    <div class="panel mb-4">
        <div class="panel-header">
            <span class="panel-title">Endereço da horta</span>
        </div>
        <div class="panel-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="Endereco.Cep" class="field-label"></label>
                    <input asp-for="Endereco.Cep" class="form-control" placeholder="00000-000" />
                    <span asp-validation-for="Endereco.Cep" class="hint-text text-danger"></span>
                </div>
                <div class="col-md-5">
                    <label asp-for="Endereco.CidadeId" class="field-label"></label>
                    <select asp-for="Endereco.CidadeId" asp-items="ViewBag.Cidades" class="form-select">
                        <option value="">Selecione...</option>
                    </select>
                    <span asp-validation-for="Endereco.CidadeId" class="hint-text text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Endereco.Rua" class="field-label"></label>
                    <input asp-for="Endereco.Rua" class="form-control" />
                    <span asp-validation-for="Endereco.Rua" class="hint-text text-danger"></span>
                </div>
                <div class="col-md-2">
                    <label asp-for="Endereco.Numero" class="field-label"></label>
                    <input asp-for="Endereco.Numero" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Endereco.Bairro" class="field-label"></label>
                    <input asp-for="Endereco.Bairro" class="form-control" />
                    <span asp-validation-for="Endereco.Bairro" class="hint-text text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Endereco.Complemento" class="field-label"></label>
                    <input asp-for="Endereco.Complemento" class="form-control" />
                </div>
            </div>
        </div>
    </div>

    <div class="panel mb-4">
        <div class="panel-header">
            <span class="panel-title">Canteiros</span>
            <button type="button" class="btn btn-sm ch-btn-edit" id="btnAddCanteiro">
                + Adicionar canteiro
            </button>
        </div>
        <div class="table-wrapper" style="border-radius:0;border:none;box-shadow:none;">
            <table>
                <thead>
                    <tr>
                        <th>Identificação</th>
                        <th>Dimensões</th>
                        <th style="width:150px;">Status</th>
                        <th style="width:80px;text-align:center;">Remover</th>
                    </tr>
                </thead>
                <tbody id="canteirosBody">
                    @for (var i = 0; i < Model.Canteiros.Count; i++)
                    {
                        @await Html.PartialAsync("_LinhaCanteiro", new CanteiroLinhaEditorModel { Index = i, Linha = Model.Canteiros[i] })
                    }
                </tbody>
            </table>
        </div>
        <div id="canteirosEmpty" class="py-4 text-center text-muted"
             style="display:@(Model.Canteiros.Count == 0 ? "block" : "none");font-size:.9rem;">
            Nenhum canteiro adicionado. Clique em <strong>+ Adicionar canteiro</strong> para começar.
        </div>
    </div>

    <div class="panel mb-4">
        <div class="panel-header">
            <span class="panel-title">Ferramentas</span>
            <button type="button" class="btn btn-sm ch-btn-edit" id="btnAddFerramenta">
                + Adicionar ferramenta
            </button>
        </div>
        <div class="table-wrapper" style="border-radius:0;border:none;box-shadow:none;">
            <table>
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th style="width:150px;">Status</th>
                        <th style="width:80px;text-align:center;">Remover</th>
                    </tr>
                </thead>
                <tbody id="ferramentasBody">
                    @for (var i = 0; i < Model.Ferramentas.Count; i++)
                    {
                        @await Html.PartialAsync("_LinhaFerramenta", new FerramentaLinhaEditorModel { Index = i, Linha = Model.Ferramentas[i] })
                    }
                </tbody>
            </table>
        </div>
        <div id="ferramentasEmpty" class="py-4 text-center text-muted"
             style="display:@(Model.Ferramentas.Count == 0 ? "block" : "none");font-size:.9rem;">
            Nenhuma ferramenta adicionada. Clique em <strong>+ Adicionar ferramenta</strong> para começar.
        </div>
    </div>


    <div class="d-flex gap-3 align-items-center pb-4">
        <button type="submit" class="btn btn-primary btn-lg">
            Cadastrar horta
        </button>
        <a asp-action="Index" class="btn btn-secondary">
            Cancelar
        </a>
    </div>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(function () {
            $('.js-select2-responsavel').select2({
                width: '100%'
            });
        });

        (function () {
            let cIx = @Model.Canteiros.Count;
            let fIx = @Model.Ferramentas.Count;
            const urlC = @Html.Raw(Json.Serialize(Url.Action("NovoCanteiroLinha", "CadastroHortas")));
            const urlF = @Html.Raw(Json.Serialize(Url.Action("NovoFerramentaLinha", "CadastroHortas")));

            function toggleEmpty(bodyId, emptyId) {
                const hasRows = document.getElementById(bodyId).querySelectorAll('tr').length > 0;
                document.getElementById(emptyId).style.display = hasRows ? 'none' : 'block';
            }

            document.getElementById('btnAddCanteiro').addEventListener('click', async function () {
                const res = await fetch(urlC + '?i=' + cIx);
                const html = await res.text();
                document.getElementById('canteirosBody').insertAdjacentHTML('beforeend', html);
                cIx++;
                toggleEmpty('canteirosBody', 'canteirosEmpty');
            });

            document.getElementById('btnAddFerramenta').addEventListener('click', async function () {
                const res = await fetch(urlF + '?i=' + fIx);
                const html = await res.text();
                document.getElementById('ferramentasBody').insertAdjacentHTML('beforeend', html);
                fIx++;
                toggleEmpty('ferramentasBody', 'ferramentasEmpty');
            });

            document.getElementById('canteirosBody').addEventListener('click', function (e) {
                if (e.target.closest('[data-remove-row]')) {
                    e.target.closest('tr').remove();
                    toggleEmpty('canteirosBody', 'canteirosEmpty');
                }
            });

            document.getElementById('ferramentasBody').addEventListener('click', function (e) {
                if (e.target.closest('[data-remove-row]')) {
                    e.target.closest('tr').remove();
                    toggleEmpty('ferramentasBody', 'ferramentasEmpty');
                }
            });
        })();
    </script>
}
