@model HortaCadastroViewModel
@{
    ViewData["Title"] = "Nova Horta";
}

<div class="ch-form-header ch-form-header--create">
    <a class="btn-back" asp-action="Index">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/></svg>
        Voltar
    </a>
    <div class="ch-form-header__content">
        <span class="ch-form-header__icon" aria-hidden="true">🌱</span>
        <div>
            <h1 class="ch-form-header__title">Nova Horta</h1>
            <p class="ch-form-header__sub">Preencha os dados para cadastrar uma nova horta comunitária</p>
        </div>
    </div>
</div>

<div asp-validation-summary="All" class="alert alert-danger ch-validation-summary"></div>

<form asp-action="Create" method="post" id="formHorta" novalidate>

    <!-- Seção: Dados da horta -->
    <div class="ch-section">
        <div class="ch-section__header">
            <span class="ch-section__num">1</span>
            <div>
                <h2 class="ch-section__title">Dados da Horta</h2>
                <p class="ch-section__desc">Informações principais da horta</p>
            </div>
        </div>
        <div class="ch-section__body">
            <div class="ch-field-grid">
                <div class="ch-field ch-field--span2">
                    <label asp-for="Nome" class="field-label">
                        Nome da horta <span class="ch-required" aria-label="obrigatório">*</span>
                    </label>
                    <input asp-for="Nome" class="ch-input" placeholder="Ex: Horta Comunitária do Bairro Verde" />
                    <span asp-validation-for="Nome" class="ch-validation-msg"></span>
                </div>
                <div class="ch-field ch-field--span2">
                    <label asp-for="UsuarioId" class="field-label">
                        Responsável <span class="ch-required" aria-label="obrigatório">*</span>
                    </label>
                    <div class="ch-select-wrap">
                        <select asp-for="UsuarioId" asp-items="ViewBag.Usuarios" class="ch-input ch-select">
                            <option value="">Selecione o responsável...</option>
                        </select>
                        <span class="ch-select-arrow" aria-hidden="true">▾</span>
                    </div>
                    <span asp-validation-for="UsuarioId" class="ch-validation-msg"></span>
                </div>
                <div class="ch-field ch-field--full">
                    <label asp-for="Regras" class="field-label">Regras da horta</label>
                    <textarea asp-for="Regras" class="ch-input ch-textarea" rows="4" placeholder="Descreva as regras e orientações para os usuários desta horta..."></textarea>
                </div>
            </div>
        </div>
    </div>

    <!-- Seção: Endereço -->
    <div class="ch-section">
        <div class="ch-section__header">
            <span class="ch-section__num">2</span>
            <div>
                <h2 class="ch-section__title">Endereço</h2>
                <p class="ch-section__desc">Localização da horta</p>
            </div>
        </div>
        <div class="ch-section__body">
            <div class="ch-field-grid">
                <div class="ch-field">
                    <label asp-for="Endereco.Cep" class="field-label">CEP <span class="ch-required">*</span></label>
                    <input asp-for="Endereco.Cep" class="ch-input" placeholder="00000-000" />
                    <span asp-validation-for="Endereco.Cep" class="ch-validation-msg"></span>
                </div>
                <div class="ch-field ch-field--span2">
                    <label asp-for="Endereco.CidadeId" class="field-label">Cidade <span class="ch-required">*</span></label>
                    <div class="ch-select-wrap">
                        <select asp-for="Endereco.CidadeId" asp-items="ViewBag.Cidades" class="ch-input ch-select">
                            <option value="">Selecione a cidade...</option>
                        </select>
                        <span class="ch-select-arrow" aria-hidden="true">▾</span>
                    </div>
                    <span asp-validation-for="Endereco.CidadeId" class="ch-validation-msg"></span>
                </div>
                <div class="ch-field ch-field--span2">
                    <label asp-for="Endereco.Rua" class="field-label">Rua <span class="ch-required">*</span></label>
                    <input asp-for="Endereco.Rua" class="ch-input" placeholder="Nome da rua ou avenida" />
                    <span asp-validation-for="Endereco.Rua" class="ch-validation-msg"></span>
                </div>
                <div class="ch-field">
                    <label asp-for="Endereco.Numero" class="field-label">Número</label>
                    <input asp-for="Endereco.Numero" class="ch-input" placeholder="S/N" />
                </div>
                <div class="ch-field ch-field--span2">
                    <label asp-for="Endereco.Bairro" class="field-label">Bairro <span class="ch-required">*</span></label>
                    <input asp-for="Endereco.Bairro" class="ch-input" placeholder="Nome do bairro" />
                    <span asp-validation-for="Endereco.Bairro" class="ch-validation-msg"></span>
                </div>
                <div class="ch-field ch-field--span2">
                    <label asp-for="Endereco.Complemento" class="field-label">Complemento</label>
                    <input asp-for="Endereco.Complemento" class="ch-input" placeholder="Apto, bloco, referência..." />
                </div>
            </div>
        </div>
    </div>

    <!-- Seção: Canteiros -->
    <div class="ch-section">
        <div class="ch-section__header">
            <span class="ch-section__num">3</span>
            <div>
                <h2 class="ch-section__title">Canteiros</h2>
                <p class="ch-section__desc">Parcelas de cultivo disponíveis nesta horta</p>
            </div>
            <button type="button" class="btn btn-secondary ch-add-btn" id="btnAddCanteiro">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2"/></svg>
                Adicionar Canteiro
            </button>
        </div>
        <div class="ch-section__body ch-section__body--table">
            <div id="canteiros-vazio" class="ch-list-empty @(Model.Canteiros.Any() ? "hidden" : "")">
                <span aria-hidden="true">🪴</span> Nenhum canteiro adicionado. Clique em "Adicionar Canteiro" para começar.
            </div>
            <div class="table-wrapper ch-inner-table @(!Model.Canteiros.Any() ? "hidden" : "")" id="canteiros-tabela-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Identificação</th>
                            <th>Dimensões</th>
                            <th>Status</th>
                            <th style="width:90px;text-align:center;">Remover</th>
                        </tr>
                    </thead>
                    <tbody id="canteirosBody">
                        @for (var i = 0; i < Model.Canteiros.Count; i++)
                        {
                            @await Html.PartialAsync("_LinhaCanteiro", new CanteiroLinhaEditorModel { Index = i, Linha = Model.Canteiros[i] })
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Seção: Ferramentas -->
    <div class="ch-section">
        <div class="ch-section__header">
            <span class="ch-section__num">4</span>
            <div>
                <h2 class="ch-section__title">Ferramentas</h2>
                <p class="ch-section__desc">Equipamentos disponíveis para empréstimo</p>
            </div>
            <button type="button" class="btn btn-secondary ch-add-btn" id="btnAddFerramenta">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2"/></svg>
                Adicionar Ferramenta
            </button>
        </div>
        <div class="ch-section__body ch-section__body--table">
            <div id="ferramentas-vazio" class="ch-list-empty @(Model.Ferramentas.Any() ? "hidden" : "")">
                <span aria-hidden="true">🔧</span> Nenhuma ferramenta adicionada. Clique em "Adicionar Ferramenta" para começar.
            </div>
            <div class="table-wrapper ch-inner-table @(!Model.Ferramentas.Any() ? "hidden" : "")" id="ferramentas-tabela-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Nome da Ferramenta</th>
                            <th>Status</th>
                            <th style="width:90px;text-align:center;">Remover</th>
                        </tr>
                    </thead>
                    <tbody id="ferramentasBody">
                        @for (var i = 0; i < Model.Ferramentas.Count; i++)
                        {
                            @await Html.PartialAsync("_LinhaFerramenta", new FerramentaLinhaEditorModel { Index = i, Linha = Model.Ferramentas[i] })
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Barra de ações -->
    <div class="ch-form-actions">
        <a class="btn btn-secondary" asp-action="Index">Cancelar</a>
        <button type="submit" class="btn btn-primary ch-submit-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M2 1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4.5a.5.5 0 0 0-.146-.354l-3-3A.5.5 0 0 0 11.5 1zm3.5 14a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m7-14.5V4H13a1 1 0 0 1-1-1V.5zM11 8H5a1 1 0 0 0 0 2h6a1 1 0 0 0 0-2"/></svg>
            Salvar Horta
        </button>
    </div>

</form>

@section Styles {
    <partial name="_CadastroHortasStyles" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            let cIx = @Model.Canteiros.Count;
            let fIx = @Model.Ferramentas.Count;
            const urlC = @Html.Raw(Json.Serialize(Url.Action("NovoCanteiroLinha", "CadastroHortas")));
            const urlF = @Html.Raw(Json.Serialize(Url.Action("NovoFerramentaLinha", "CadastroHortas")));

            function showTable(wrapId, emptyId) {
                document.getElementById(wrapId).classList.remove('hidden');
                document.getElementById(emptyId).classList.add('hidden');
            }

            document.getElementById('btnAddCanteiro').addEventListener('click', async function () {
                const res = await fetch(urlC + '?i=' + cIx);
                const html = await res.text();
                document.getElementById('canteirosBody').insertAdjacentHTML('beforeend', html);
                showTable('canteiros-tabela-wrap', 'canteiros-vazio');
                cIx++;
            });
            document.getElementById('btnAddFerramenta').addEventListener('click', async function () {
                const res = await fetch(urlF + '?i=' + fIx);
                const html = await res.text();
                document.getElementById('ferramentasBody').insertAdjacentHTML('beforeend', html);
                showTable('ferramentas-tabela-wrap', 'ferramentas-vazio');
                fIx++;
            });
        })();
    </script>
}
