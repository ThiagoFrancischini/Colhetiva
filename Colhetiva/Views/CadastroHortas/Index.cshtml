@model IReadOnlyList<Horta>
@{
    ViewData["Title"] = "Cadastro de Hortas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Cadastro de Hortas</h1>
    <a class="btn btn-success" asp-action="Create">Nova horta</a>
</div>

@if (TempData["MensagemSucesso"] != null)
{
    <div class="alert alert-success">@TempData["MensagemSucesso"]</div>
}

<table class="table table-striped table-bordered align-middle">
    <thead class="table-light">
        <tr>
            <th>Nome</th>
            <th>Responsável</th>
            <th>Cidade</th>
            <th class="text-end" style="width: 200px;">Ações</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var h in Model)
    {
        <tr>
            <td>@h.Nome</td>
            <td>@(h.Usuario?.Nome ?? h.Usuario?.Email ?? "—")</td>
            <td>@(h.Endereco?.Cidade?.Nome ?? "—")</td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@h.Id">Editar</a>
                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@h.Id">Excluir</a>
            </td>
        </tr>
    }
    </tbody>
</table>

@if (Model.Count == 0)
{
    <p class="text-muted">Nenhuma horta cadastrada.</p>
}
