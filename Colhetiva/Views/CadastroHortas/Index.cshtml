@model IReadOnlyList<Horta>
@{
    ViewData["Title"] = "Cadastro de Hortas";
}

<div class="ch-page-header">
    <div class="ch-page-header__left">
        <div>
            <h1 class="ch-page-header__title">Cadastro de Hortas</h1>
            <p class="ch-page-header__sub">Gerencie as hortas comunitárias do sistema</p>
        </div>
    </div>
    <a class="btn btn-primary" asp-action="Create">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2" /></svg>
        Nova Horta
    </a>
</div>

@if (TempData["MensagemSucesso"] != null)
{
    <div class="alert alert-success ch-alert-animate" role="alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" /></svg>
        @TempData["MensagemSucesso"]
    </div>
}

@if (Model.Count == 0)
{
    <div class="ch-empty">
        <div class="ch-empty__icon">🪴</div>
        <p class="ch-empty__msg">Nenhuma horta cadastrada ainda.</p>
        <a class="btn btn-primary" asp-action="Create">Cadastrar primeira horta</a>
    </div>
}
else
{
    <div class="panel">
        <div class="table-wrapper" style="border:none;border-radius:0;box-shadow:none;">
            <table>
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Responsável</th>
                        <th>Cidade</th>
                        <th style="width:200px;text-align:right;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var h in Model)
                    {
                        <tr>
                            <td><span class="ch-horta-nome">@h.Nome</span></td>
                            <td>@(h.Usuario?.Nome ?? h.Usuario?.Email ?? "—")</td>
                            <td>@(h.Endereco?.Cidade?.Nome ?? "—")</td>
                            <td>
                                <div class="table-actions" style="justify-content:flex-end;">
                                    <a class="btn ch-btn-edit" asp-action="Edit" asp-route-id="@h.Id" title="Editar">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325" /></svg>
                                        Editar
                                    </a>
                                    <a class="btn ch-btn-delete" asp-action="Delete" asp-route-id="@h.Id" title="Excluir">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z" /><path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z" /></svg>
                                        Excluir
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <p class="ch-total-count">@Model.Count horta(s) cadastrada(s)</p>
}