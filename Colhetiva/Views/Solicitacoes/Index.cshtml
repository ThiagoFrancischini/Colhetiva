@model Colhetiva.Core.Entities.Horta
@{
    ViewData["Title"] = "Solicitar Canteiro";
    var pendentes = ViewBag.PendingCanteiros as System.Collections.Generic.List<Guid> ?? new();
}

<div class="section-header">
    <h2>@Model.Nome</h2>
    <p class="text-muted">@Model.Endereco?.Rua @Model.Endereco?.Numero — @Model.Endereco?.Bairro — @Model.Endereco?.Cidade?.Nome / @Model.Endereco?.Cidade?.Estado?.Nome</p>
</div>

@if (TempData["MensagemSucesso"] != null)
{
    <div class="alert alert-success">@TempData["MensagemSucesso"]</div>
}
@if (TempData["MensagemErro"] != null)
{
    <div class="alert alert-danger">@TempData["MensagemErro"]</div>
}
@if (TempData["MensagemInfo"] != null)
{
    <div class="alert alert-info">@TempData["MensagemInfo"]</div>
}

@if (!string.IsNullOrWhiteSpace(Model.Regras))
{
    <div class="card mb-3">
        <div class="card-header">Regras da horta</div>
        <div class="card-body">
            <p class="card-text">@Model.Regras</p>
        </div>
    </div>
}

<div class="card">
    <div class="card-header">Canteiros</div>
    <div class="card-body p-0">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Identificação</th>
                    <th>Dimensões</th>
                    <th>Status</th>
                    <th style="width:150px;text-align:center;">Ação</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Canteiros.OrderBy(x => x.Identificacao))
                {
                    var isPending = pendentes.Contains(c.Id);
                    <tr>
                        <td>@c.Identificacao</td>
                        <td>@c.Dimensoes</td>
                        <td>@c.Status</td>
                        <td class="text-center">
                            @if (c.Status == Colhetiva.Core.Enums.StatusCanteiro.Disponivel && !isPending)
                            {
                                <form asp-action="Solicitar" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="canteiroId" value="@c.Id" />
                                    <input type="hidden" name="hortaId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-primary btn-sm">Solicitar</button>
                                </form>
                            }
                            else if (isPending)
                            {
                                <span class="badge bg-warning text-dark">Pendente</span>
                            }
                            else
                            {
                                <button class="btn btn-secondary btn-sm" disabled>Indisponível</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <a href="@Url.Action("Index", "Home")" class="btn btn-link">Voltar às hortas</a>
</div>