<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Colhetiva</title>
    <link rel="stylesheet" href="~/css/app.css" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-light bg-light border-bottom">
        <div style="display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; width: 100%; padding: 0.5rem 1rem;">
            @{
                var nomeUsuario = Context.Session.GetString("UsuarioNome");
            }
            
            @if (!string.IsNullOrEmpty(nomeUsuario))
            {
                <!-- Left: Welcome message -->
                <div style="justify-self: start;">
                    <span class="navbar-text text-dark mb-0">
                        Bem-vindo, <strong>@nomeUsuario</strong>
                    </span>
                </div>
                
                <!-- Center: Brand -->
                <div style="justify-self: center;">
                    <a class="navbar-brand fw-bold text-success mb-0" href="@Url.Action("Index", "Home")">Colhetiva</a>
                </div>
                
                <!-- Right: Action buttons -->
                <div style="justify-self: end; display: flex; align-items: center; gap: 0.5rem;">
                    @{
                        var usuarioRole = Context.Session.GetString("UsuarioRole");
                        var isAdmin = string.Equals(usuarioRole, "ADMIN", StringComparison.OrdinalIgnoreCase);
                    }
                    @if (isAdmin)
                    {
                        <a class="btn btn-outline-success btn-sm d-inline-flex align-items-center gap-1" href="@Url.Action("Index", "CadastroHortas")" title="Cadastro de Hortas">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-flower1" viewBox="0 0 16 16" aria-hidden="true">
                                <path d="M6.174 1.184a2 2 0 0 1 3.652 0A2 2 0 0 1 12.99 3.01q.137.57.395 1.093a2.9 2.9 0 0 1 .896 1.295 2.9 2.9 0 0 1 0 2.207 2.9 2.9 0 0 1-.896 1.295 2.9 2.9 0 0 1-1.102.792 2.9 2.9 0 0 1-2.103 0 2.9 2.9 0 0 1-1.102-.792q-.258-.523-.395-1.093A2 2 0 0 1 1.99 4.814a2 2 0 0 1 1.183-3.826zM8 1.5c-.506 0-.974.26-1.23.674L8 3.118l1.23-1.944A1.5 1.5 0 0 0 8 1.5m2.442.546c.17.615-.297 1.223-.872 1.408l-.318.112c-.666.22-1.11.78-1.11 1.416v.102a2.9 2.9 0 0 1 .26.123c.24.113.475.24.702.382V7.5c0 .563.12 1.013.337 1.349.216.335.543.521.89.521s.674-.186.89-.521A1.5 1.5 0 0 0 12.5 7.5v-.382l.702-.382q.137-.066.26-.123v-.102c0-.636-.444-1.196-1.11-1.416l-.318-.112c-.575-.185-1.043-.793-.872-1.408A1.5 1.5 0 0 1 12.5 4M4.75 5.562a2.9 2.9 0 0 0-.499.667l-.112.319c-.22.666-.78 1.11-1.416 1.11h-.102q-.123-.057-.26-.123c-.24-.113-.475-.24-.702-.382V7.5c0 .638.45 1.196 1.11 1.416l.318.112c.575.185 1.043.793.872 1.408a1.5 1.5 0 0 1-1.102 1.79 1.5 1.5 0 0 1-1.79-1.102 2 2 0 0 1-.395-1.093A2 2 0 0 1 4.75 5.562M8 11.5a1.5 1.5 0 0 1-1.23-.674L8 9.882l1.23 1.944A1.5 1.5 0 0 1 8 11.5"/>
                            </svg>
                            <span>Cadastro de Hortas</span>
                        </a>
                    }
                    <a class="btn btn-outline-secondary btn-sm" href="@Url.Action("Index", "Profile")">
                        Perfil
                    </a>
                    <a class="btn btn-outline-danger btn-sm" href="@Url.Action("Logout", "Account")">
                        Sair
                    </a>
                </div>
            }
            else
            {
                <!-- When not logged in, just show brand centered -->
                <div style="grid-column: 1 / span 3; text-align: center;">
                    <a class="navbar-brand fw-bold text-success mb-0" href="@Url.Action("Index", "Home")">Colhetiva</a>
                </div>
            }
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <footer class="text-center mt-4 py-3 border-top">
        <p class="text-muted mb-0">Universidade de Caxias do Sul, 2025</p>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/inputmask@5.0.8/dist/inputmask.min.js"></script>
    <script src="~/js/app.js"></script>
    <script src="~/js/masks.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>