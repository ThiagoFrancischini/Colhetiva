@inject Colhetiva.Core.Interfaces.Service.INotificacaoService NotificacaoService
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Colhetiva</title>
    <link rel="stylesheet" href="~/css/app.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-light bg-light border-bottom">
        <div style="display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; width: 100%; padding: 0.5rem 1rem;">
            @{
                var nomeUsuario = Context.Session.GetString("UsuarioNome");
            }
           
            @if (!string.IsNullOrEmpty(nomeUsuario))
            {
                <div style="justify-self: start;">
                    <span class="navbar-text text-dark mb-0">
                        Bem-vindo, <strong>@nomeUsuario</strong>
                    </span>
                </div>
                
                <div style="justify-self: center;">
                    <a class="navbar-brand fw-bold text-success mb-0" href="@Url.Action("Index", "Home")">Colhetiva</a>
                </div>
                
                <div style="justify-self: end; display: flex; align-items: center; gap: 0.5rem;">
                    @{
                        var usuarioRole = Context.Session.GetString("UsuarioRole");
                        var isAdmin = string.Equals(usuarioRole, "ADMIN", StringComparison.OrdinalIgnoreCase);
                    }
                    @if (isAdmin)
                    {
                        <a class="btn btn-outline-success btn-sm d-inline-flex align-items-center gap-1" href="@Url.Action("Index", "CadastroHortas")" title="Cadastro de Hortas">
                            <span>Cadastro de Hortas</span>
                        </a>
                    }
                    <a class="btn btn-outline-secondary btn-sm" href="@Url.Action("Diario", "RegistroAtividades")">
                        Meu Diário
                    </a>
                    @{
                        var usuarioIdStr = Context.Session.GetString("UsuarioId");
                        var naoLidas = Guid.TryParse(usuarioIdStr, out var usuarioIdSino)
                            ? await NotificacaoService.GetCountNaoLidasAsync(usuarioIdSino)
                            : 0;
                    }
                    <a class="btn btn-outline-secondary btn-sm" style="position:relative;" href="@Url.Action("Index", "Notificacoes")" title="Notificações">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                            <path d="M8 16a2 2 0 0 0 2-2H6a2 2 0 0 0 2 2M8 1.918l-.797.161A4 4 0 0 0 4 6c0 .628-.134 2.197-.459 3.742-.16.767-.376 1.566-.663 2.258h10.244c-.287-.692-.502-1.49-.663-2.258C12.134 8.197 12 6.628 12 6a4 4 0 0 0-3.203-3.92zM14.22 12c.223.447.481.801.78 1H1c.299-.199.557-.553.78-1C2.68 10.2 3 6.88 3 6c0-2.42 1.72-4.44 4.005-4.901a1 1 0 1 1 1.99 0A5 5 0 0 1 13 6c0 .88.32 4.2 1.22 6" />
                        </svg>
                        <span>Notificações</span>
                        @if (naoLidas > 0)
                        {
                            <span class="notif-badge">@naoLidas</span>
                        }
                    </a>
                    <a class="btn btn-outline-secondary btn-sm" href="@Url.Action("Index", "Profile")">
                        Perfil
                    </a>
                    <a class="btn btn-outline-danger btn-sm" href="@Url.Action("Logout", "Account")">
                        Sair
                    </a>
                </div>
            }
            else
            {
                <div style="grid-column: 1 / span 3; text-align: center;">
                    <a class="navbar-brand fw-bold text-success mb-0" href="@Url.Action("Index", "Home")">Colhetiva</a>
                </div>
            }
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <footer class="text-center mt-4 py-3 border-top">
        <p class="text-muted mb-0">Universidade de Caxias do Sul, 2025</p>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/inputmask@5.0.8/dist/inputmask.min.js"></script>
    <script src="~/js/app.js"></script>
    <script src="~/js/masks.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>