@model Colhetiva.Core.Entities.Horta
@{
    ViewData["Title"] = "Gerenciar Horta";
    var solicitacoesPendentes = ViewBag.SolicitacoesPendentes as List<Colhetiva.Core.Entities.Solicitacao> ?? new();
    var participantesAtivos = ViewBag.ParticipantesAtivos as List<Colhetiva.Core.Entities.Solicitacao> ?? new();
    var emprestimosPendentes = ViewBag.EmprestimosPendentes as List<Colhetiva.Core.Entities.Emprestimo> ?? new();
    var totalParticipantsHorta = (int?)(ViewBag.TotalParticipantsHorta) ?? 0;
    var taxaOcupacaoHorta = (decimal?)(ViewBag.TaxaOcupacaoHorta) ?? 0m;
    var ferramentasEmUsoHorta = (int?)(ViewBag.FerramentasEmUsoHorta) ?? 0;
}

<div class="ch-page-header mb-4">
    <div class="ch-page-header__left">
        <div>
            <h1 class="ch-page-header__title">Gerenciar @Model.Nome</h1>
            <p class="ch-page-header__sub">Solicitações, empréstimos e participantes desta horta</p>
        </div>
    </div>
    <a href="@Url.Action("Details", new { id = Model.Id })" class="btn-back" style="border-color:rgba(255,255,255,.35);color:rgba(255,255,255,.9);background:transparent;">
        ← Voltar para a horta
    </a>
</div>

@if (TempData["MensagemSucesso"] != null)
{
    <div class="alert alert-success ch-alert-animate mb-3">@TempData["MensagemSucesso"]</div>
}
@if (TempData["MensagemErro"] != null)
{
    <div class="alert alert-danger ch-alert-animate mb-3">@TempData["MensagemErro"]</div>
}
@if (TempData["MensagemInfo"] != null)
{
    <div class="alert alert-info ch-alert-animate mb-3">@TempData["MensagemInfo"]</div>
}

<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1.5rem;">
    <div class="metric-card">
        <div class="metric-label">Participantes ativos</div>
        <div class="metric-num">@totalParticipantsHorta</div>
    </div>
    <div class="metric-card">
        <div class="metric-label">Taxa de ocupação</div>
        <div class="metric-num">@taxaOcupacaoHorta<small style="font-size:1rem;font-weight:500;color:var(--gray-400);">%</small></div>
    </div>
    <div class="metric-card">
        <div class="metric-label">Ferramentas em uso</div>
        <div class="metric-num">@ferramentasEmUsoHorta</div>
    </div>
</div>

<div class="panel mb-4">
    <div class="panel-header">
        <span class="panel-title">Solicitações de canteiro pendentes</span>
        @if (solicitacoesPendentes.Any())
        {
            <span class="badge" style="background:var(--status-maint-bg);color:var(--status-maint);border:1.5px solid var(--status-maint);">
                @solicitacoesPendentes.Count pendente@(solicitacoesPendentes.Count != 1 ? "s" : "")
            </span>
        }
        else
        {
            <span class="badge badge-free">✓ Em dia</span>
        }
    </div>
    @if (!solicitacoesPendentes.Any())
    {
        <div class="py-4 text-center text-muted" style="font-size:.9rem;">
            Nenhuma solicitação pendente de canteiro.
        </div>
    }
    else
    {
        <div class="table-wrapper" style="border-radius:0;border:none;box-shadow:none;">
            <table>
                <thead>
                    <tr>
                        <th>Solicitante</th>
                        <th>Canteiro</th>
                        <th style="width:130px;">Data do Pedido</th>
                        <th style="width:200px;text-align:center;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in solicitacoesPendentes)
                    {
                        <tr>
                            <td><strong>@s.Usuario?.Nome</strong></td>
                            <td>@s.Canteiro.Identificacao</td>
                            <td style="font-size:.8rem;color:var(--gray-400);">@s.DataPedido.ToLocalTime().ToString("g")</td>
                            <td class="text-center">
                                <div class="table-actions justify-content-center">
                                    <form asp-controller="Solicitacoes" asp-action="Aprovar" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="solicitacaoId" value="@s.Id" />
                                        <button type="submit" class="btn btn-sm"
                                                style="background:var(--status-free-bg);color:var(--status-free);border:1.5px solid var(--status-free);font-weight:700;">
                                            ✓ Aprovar
                                        </button>
                                    </form>
                                    <form asp-controller="Solicitacoes" asp-action="Reprovar" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="solicitacaoId" value="@s.Id" />
                                        <button type="submit" class="btn btn-sm"
                                                style="background:var(--status-busy-bg);color:var(--status-busy);border:1.5px solid var(--status-busy);font-weight:700;">
                                            ✕ Recusar
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="panel mb-4">
    <div class="panel-header">
        <span class="panel-title">Pedidos de empréstimo pendentes</span>
        @if (emprestimosPendentes.Any())
        {
            <span class="badge" style="background:var(--status-maint-bg);color:var(--status-maint);border:1.5px solid var(--status-maint);">
                @emprestimosPendentes.Count pendente@(emprestimosPendentes.Count != 1 ? "s" : "")
            </span>
        }
        else
        {
            <span class="badge badge-free">✓ Em dia</span>
        }
    </div>
    @if (!emprestimosPendentes.Any())
    {
        <div class="py-4 text-center text-muted" style="font-size:.9rem;">
            Nenhum pedido pendente de empréstimo.
        </div>
    }
    else
    {
        <div class="table-wrapper" style="border-radius:0;border:none;box-shadow:none;">
            <table>
                <thead>
                    <tr>
                        <th>Solicitante</th>
                        <th>Ferramenta</th>
                        <th style="width:130px;">Pedido</th>
                        <th style="width:200px;text-align:center;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in emprestimosPendentes)
                    {
                        <tr>
                            <td><strong>@e.Usuario?.Nome</strong></td>
                            <td>@e.Ferramenta.Nome</td>
                            <td style="font-size:.8rem;color:var(--gray-400);">@e.DataRetirada.ToLocalTime().ToString("g")</td>
                            <td class="text-center">
                                <div class="table-actions justify-content-center">
                                    <form asp-controller="Emprestimos" asp-action="Aprovar" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="emprestimoId" value="@e.Id" />
                                        <button type="submit" class="btn btn-sm"
                                                style="background:var(--status-free-bg);color:var(--status-free);border:1.5px solid var(--status-free);font-weight:700;">
                                            ✓ Aprovar
                                        </button>
                                    </form>
                                    <form asp-controller="Emprestimos" asp-action="Reprovar" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="emprestimoId" value="@e.Id" />
                                        <button type="submit" class="btn btn-sm"
                                                style="background:var(--status-busy-bg);color:var(--status-busy);border:1.5px solid var(--status-busy);font-weight:700;">
                                            ✕ Recusar
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="panel mb-4">
    <div class="panel-header">
        <span class="panel-title">Participantes atuais</span>
        @if (participantesAtivos.Any())
        {
            <span class="badge badge-free">@participantesAtivos.Count ativo@(participantesAtivos.Count != 1 ? "s" : "")</span>
        }
    </div>
    @if (!participantesAtivos.Any())
    {
        <div class="py-4 text-center text-muted" style="font-size:.9rem;">
            Nenhum participante com canteiro ativo no momento.
        </div>
    }
    else
    {
        <div class="table-wrapper" style="border-radius:0;border:none;box-shadow:none;">
            <table>
                <thead>
                    <tr>
                        <th>Participante</th>
                        <th>Canteiro</th>
                        <th style="width:130px;">Desde</th>
                        <th style="width:160px;text-align:center;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in participantesAtivos)
                    {
                        <tr>
                            <td><strong>@p.Usuario?.Nome</strong></td>
                            <td>@p.Canteiro.Identificacao</td>
                            <td style="font-size:.8rem;color:var(--gray-400);">@p.DataPedido.ToLocalTime().ToString("g")</td>
                            <td class="text-center">
                                <form asp-controller="Solicitacoes" asp-action="Sair" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="solicitacaoId" value="@p.Id" />
                                    <button type="submit" class="btn btn-sm"
                                            style="background:var(--status-busy-bg);color:var(--status-busy);border:1.5px solid var(--status-busy);font-weight:700;">
                                        ✕ Remover
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
