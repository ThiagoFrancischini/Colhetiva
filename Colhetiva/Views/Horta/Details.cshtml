@model Colhetiva.Core.Entities.Horta
@using Colhetiva.Core.Enums
@{
    ViewData["Title"] = "Detalhes da Horta";
    var pendentes = ViewBag.PendingCanteiros as System.Collections.Generic.List<Guid> ?? new();
    var myActive = ViewBag.MyActiveEmprestimos as List<Guid> ?? new List<Guid>();
    var isAdminSession = string.Equals(Context.Session.GetString("UsuarioRole"), "ADMIN", StringComparison.OrdinalIgnoreCase);
    var podeGerenciar = (bool?)(ViewBag.PodeGerenciar) ?? false;
    var solicitacoesPendentes = ViewBag.SolicitacoesPendentes as List<Colhetiva.Core.Entities.Solicitacao> ?? new();
    var participantesAtivos = ViewBag.ParticipantesAtivos as List<Colhetiva.Core.Entities.Solicitacao> ?? new();
    var emprestimosPendentes = ViewBag.EmprestimosPendentes as List<Colhetiva.Core.Entities.Emprestimo> ?? new();
    var totalParticipantsHorta = (int?)(ViewBag.TotalParticipantsHorta) ?? 0;
    var taxaOcupacaoHorta = (decimal?)(ViewBag.TaxaOcupacaoHorta) ?? 0m;
    var ferramentasEmUsoHorta = (int?)(ViewBag.FerramentasEmUsoHorta) ?? 0;
    var voltarUrl = isAdminSession ? Url.Action("Index", "CadastroHortas") : Url.Action("Index", "Home");
}

<div class="ch-page-header mb-4">
    <div class="ch-page-header__left">
        <div>
            <h1 class="ch-page-header__title">@Model.Nome</h1>
            @if (Model.Endereco != null)
            {
                <p class="ch-page-header__sub">
                    @Model.Endereco.Rua@if (!string.IsNullOrWhiteSpace(Model.Endereco.Numero)){
                    <text>, @Model.Endereco.Numero</text>
                }
                — @Model.Endereco.Bairro,
                @(Model.Endereco.Cidade?.Nome)/@(Model.Endereco.Cidade?.Estado?.Nome)
            </p>
                        }
        </div>
    </div>
    <a href="@voltarUrl" class="btn-back" style="border-color:rgba(255,255,255,.35);color:rgba(255,255,255,.9);background:transparent;">
        ← Voltar
    </a>
</div>

@if (TempData["MensagemSucesso"] != null)
{
    <div class="alert alert-success ch-alert-animate mb-3">@TempData["MensagemSucesso"]</div>
}
@if (TempData["MensagemErro"] != null)
{
    <div class="alert alert-danger ch-alert-animate mb-3">@TempData["MensagemErro"]</div>
}
@if (TempData["MensagemInfo"] != null)
{
    <div class="alert alert-info ch-alert-animate mb-3">@TempData["MensagemInfo"]</div>
}

<div class="row g-4 align-items-start">

    <div class="col-md-5 col-lg-4">

        <div class="panel mb-4">
            <div class="panel-header">
                <span class="panel-title">Informações</span>
            </div>
            <div class="panel-body py-3">

                @if (Model.Endereco != null)
                {
                    <div class="info-card mb-0">
                        <div class="info-row">
                            <span class="info-row__label fw-bold text-nowrap me-2" style="min-width:90px;color:var(--green-dark);">Endereço</span>
                            <span>
                                @Model.Endereco.Rua@if (!string.IsNullOrWhiteSpace(Model.Endereco.Numero)){
                                <text>, @Model.Endereco.Numero</text>
                            }
                            — @Model.Endereco.Bairro<br />
                            @(Model.Endereco.Cidade?.Nome)/@(Model.Endereco.Cidade?.Estado?.Nome)
                            — CEP @Model.Endereco.Cep
                        </span>
                    </div>
                    <div class="info-row">
                        <span class="info-row__label fw-bold text-nowrap me-2" style="min-width:90px;color:var(--green-dark);">Gestor</span>
                        <span>@Model.Usuario?.Nome</span>
                    </div>
                </div>
                                }

                <div class="mt-3">
                    <p class="fw-bold mb-2" style="color:var(--green-dark);font-size:.9rem;">Mural Público / Regras</p>
                    <div class="mural-box">
                        @if (!string.IsNullOrWhiteSpace(Model.Regras))
                        {
                            @Model.Regras
                        }
                        else
                        {
                            <em style="color:var(--gray-400)">Sem regras cadastradas.</em>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="panel">
            <div class="panel-header">
                <span class="panel-title">Ações rápidas</span>
            </div>
            <div class="panel-body d-flex flex-column gap-2">
                @if (!isAdminSession)
                {
                    <a href="@Url.Action("Index", "Solicitacoes", new { hortaId = Model.Id })"
                       class="btn btn-primary btn-block" style="justify-content:center;">
                        Solicitar Participação na Horta
                    </a>
                    <a href="@Url.Action("Index", "Emprestimos", new { hortaId = Model.Id} )"
                       class="btn btn-secondary btn-block" style="justify-content:center;">
                        Meus Empréstimos
                    </a>
                }
                <a href="@Url.Action("Registrar", "RegistroAtividades", new { hortaId = Model.Id })"
                   class="btn btn-primary btn-block" style="justify-content:center;">
                    Registrar Atividade
                </a>
                <a href="@Url.Action("Timeline", "RegistroAtividades", new { hortaId = Model.Id })"
                   class="btn btn-secondary btn-block" style="justify-content:center;">
                    Ver Timeline da Horta
                </a>
            </div>
        </div>

    </div>

    <div class="col-md-7 col-lg-8">

        <div class="section-header mb-3">
            <h4 class="section-title m-0">Canteiros</h4>
        </div>

        <div class="table-wrapper mb-5">
            <table>
                <thead>
                    <tr>
                        <th>Identificação</th>
                        <th>Dimensões</th>
                        <th style="width:130px;">Status</th>
                        <th style="width:230px;text-align:center;">Ação</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Canteiros == null || !Model.Canteiros.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                Nenhum canteiro cadastrado.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var c in Model.Canteiros.OrderBy(x => x.Identificacao))
                        {
                            var isPending = pendentes.Contains(c.Id);
                            <tr>
                                <td><strong>@c.Identificacao</strong></td>
                                <td>@c.Dimensoes</td>
                                <td>
                                    @if (c.Status == StatusCanteiro.Disponivel)
                                    {
                                        <span class="badge badge-free">Livre</span>
                                    }
                                    else if (c.Status == StatusCanteiro.Ocupado)
                                    {
                                        <span class="badge badge-busy">Ocupado</span>
                                    }
                                    else if (c.Status == StatusCanteiro.Manutencao)
                                    {
                                        <span class="badge badge-maint">Manutenção</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@c.Status</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (c.Status == StatusCanteiro.Disponivel && !isPending)
                                    {
                                        <form asp-controller="Solicitacoes" asp-action="Solicitar" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="canteiroId" value="@c.Id" />
                                            <input type="hidden" name="hortaId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-primary btn-sm">Solicitar</button>
                                        </form>
                                    }
                                    else if (isPending)
                                    {
                                        <span class="badge" style="background:#fff8e1;color:#b36200;border:1.5px solid #e6a817;">Pendente</span>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm" disabled
                                                style="background:var(--gray-100);color:var(--gray-400);border-color:var(--gray-200);cursor:not-allowed;">
                                            Indisponível
                                        </button>
                                    }
                                    <a href="@Url.Action("Registrar", "RegistroAtividades", new { hortaId = Model.Id, canteiroId = c.Id })"
                                       class="btn btn-sm btn-secondary" title="Registrar atividade neste canteiro">
                                        Registrar
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="section-header mb-3">
            <h4 class="section-title m-0">Ferramentas</h4>
        </div>

        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th style="width:130px;">Status</th>
                        <th style="width:210px;text-align:center;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Ferramentas == null || !Model.Ferramentas.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">
                                Nenhuma ferramenta cadastrada.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var f in Model.Ferramentas.OrderBy(x => x.Nome))
                        {
                            @if (podeGerenciar)
                            {
                                <tr>
                                    <td>
                                        <input form="form-update-@f.Id" name="nome" value="@f.Nome"
                                               class="form-control form-control-sm" />
                                    </td>
                                    <td>
                                        <select form="form-update-@f.Id" name="status" class="form-select form-select-sm">
                                            @if (f.Status == StatusFerramenta.Disponivel)
                                            {
                                                <option value="Disponivel" selected>Disponível</option>
                                                <option value="EmUso">Em Uso</option>
                                                <option value="Inativa">Inativa</option>
                                            }
                                            else if (f.Status == StatusFerramenta.EmUso)
                                            {
                                                <option value="Disponivel">Disponível</option>
                                                <option value="EmUso" selected>Em Uso</option>
                                                <option value="Inativa">Inativa</option>
                                            }
                                            else
                                            {
                                                <option value="Disponivel">Disponível</option>
                                                <option value="EmUso">Em Uso</option>
                                                <option value="Inativa" selected>Inativa</option>
                                            }
                                        </select>
                                    </td>
                                    <td class="text-center">
                                        <div class="table-actions justify-content-center">
                                            <form id="form-update-@f.Id" asp-controller="Solicitacoes" asp-action="UpdateFerramenta" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="ferramentaId" value="@f.Id" />
                                                <button type="submit" class="btn btn-primary btn-sm">Salvar</button>
                                            </form>
                                            <form asp-controller="Solicitacoes" asp-action="ToggleFerramentaActive" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="ferramentaId" value="@f.Id" />
                                                <button type="submit" class="btn btn-sm"
                                                        style="@(f.Status == StatusFerramenta.Inativa
                                                                    ? "background:var(--status-free-bg);color:var(--status-free);border:1.5px solid var(--status-free);font-weight:700;"
                                                                    : "background:var(--status-busy-bg);color:var(--status-busy);border:1.5px solid var(--status-busy);font-weight:700;")">
                                                    @(f.Status == StatusFerramenta.Inativa ? "↑ Ativar" : "↓ Inativar")
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                <tr>
                                    <td>@f.Nome</td>
                                    <td>
                                        @if (f.Status == StatusFerramenta.Disponivel)
                                        {
                                            <span class="badge badge-free">Disponível</span>
                                        }
                                        else if (f.Status == StatusFerramenta.EmUso)
                                        {
                                            <span class="badge badge-busy">Em Uso</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-maint">Inativa</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="table-actions justify-content-center">
                                            @if (f.Status == StatusFerramenta.Disponivel)
                                            {
                                                <form asp-controller="Emprestimos" asp-action="Solicitar" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="ferramentaId" value="@f.Id" />
                                                    <input type="hidden" name="hortaId" value="@Model.Id" />
                                                    <button type="submit" class="btn btn-primary btn-sm">Solicitar Empréstimo</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm" disabled
                                                        style="background:var(--gray-100);color:var(--gray-400);border-color:var(--gray-200);cursor:not-allowed;">
                                                    Indisponível
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>

@if (podeGerenciar)
{
    <div class="section-header mt-5 mb-3">
        <h4 class="section-title m-0">Gestão desta horta</h4>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1.5rem;">
        <div class="metric-card">
            <div class="metric-label">Participantes ativos</div>
            <div class="metric-num">@totalParticipantsHorta</div>
        </div>
        <div class="metric-card">
            <div class="metric-label">Taxa de ocupação</div>
            <div class="metric-num">@taxaOcupacaoHorta<small style="font-size:1rem;font-weight:500;color:var(--gray-400);">%</small></div>
        </div>
        <div class="metric-card">
            <div class="metric-label">Ferramentas em uso</div>
            <div class="metric-num">@ferramentasEmUsoHorta</div>
        </div>
    </div>

    <div class="panel mb-4">
        <div class="panel-header">
            <span class="panel-title">Solicitações de canteiro pendentes</span>
            @if (solicitacoesPendentes.Any())
            {
                <span class="badge" style="background:var(--status-maint-bg);color:var(--status-maint);border:1.5px solid var(--status-maint);">
                    @solicitacoesPendentes.Count pendente@(solicitacoesPendentes.Count != 1 ? "s" : "")
                </span>
            }
            else
            {
                <span class="badge badge-free">✓ Em dia</span>
            }
        </div>
        @if (!solicitacoesPendentes.Any())
        {
            <div class="py-4 text-center text-muted" style="font-size:.9rem;">
                Nenhuma solicitação pendente de canteiro.
            </div>
        }
        else
        {
            <div class="table-wrapper" style="border-radius:0;border:none;box-shadow:none;">
                <table>
                    <thead>
                        <tr>
                            <th>Solicitante</th>
                            <th>Canteiro</th>
                            <th style="width:130px;">Data do Pedido</th>
                            <th style="width:200px;text-align:center;">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in solicitacoesPendentes)
                        {
                            <tr>
                                <td><strong>@s.Usuario?.Nome</strong></td>
                                <td>@s.Canteiro.Identificacao</td>
                                <td style="font-size:.8rem;color:var(--gray-400);">@s.DataPedido.ToLocalTime().ToString("g")</td>
                                <td class="text-center">
                                    <div class="table-actions justify-content-center">
                                        <form asp-controller="Solicitacoes" asp-action="Aprovar" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="solicitacaoId" value="@s.Id" />
                                            <button type="submit" class="btn btn-sm"
                                                    style="background:var(--status-free-bg);color:var(--status-free);border:1.5px solid var(--status-free);font-weight:700;">
                                                ✓ Aprovar
                                            </button>
                                        </form>
                                        <form asp-controller="Solicitacoes" asp-action="Reprovar" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="solicitacaoId" value="@s.Id" />
                                            <button type="submit" class="btn btn-sm"
                                                    style="background:var(--status-busy-bg);color:var(--status-busy);border:1.5px solid var(--status-busy);font-weight:700;">
                                                ✕ Recusar
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="panel mb-4">
        <div class="panel-header">
            <span class="panel-title">Pedidos de empréstimo pendentes</span>
            @if (emprestimosPendentes.Any())
            {
                <span class="badge" style="background:var(--status-maint-bg);color:var(--status-maint);border:1.5px solid var(--status-maint);">
                    @emprestimosPendentes.Count pendente@(emprestimosPendentes.Count != 1 ? "s" : "")
                </span>
            }
            else
            {
                <span class="badge badge-free">✓ Em dia</span>
            }
        </div>
        @if (!emprestimosPendentes.Any())
        {
            <div class="py-4 text-center text-muted" style="font-size:.9rem;">
                Nenhum pedido pendente de empréstimo.
            </div>
        }
        else
        {
            <div class="table-wrapper" style="border-radius:0;border:none;box-shadow:none;">
                <table>
                    <thead>
                        <tr>
                            <th>Solicitante</th>
                            <th>Ferramenta</th>
                            <th style="width:130px;">Pedido</th>
                            <th style="width:200px;text-align:center;">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in emprestimosPendentes)
                        {
                            <tr>
                                <td><strong>@e.Usuario?.Nome</strong></td>
                                <td>@e.Ferramenta.Nome</td>
                                <td style="font-size:.8rem;color:var(--gray-400);">@e.DataRetirada.ToLocalTime().ToString("g")</td>
                                <td class="text-center">
                                    <div class="table-actions justify-content-center">
                                        <form asp-controller="Emprestimos" asp-action="Aprovar" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="emprestimoId" value="@e.Id" />
                                            <button type="submit" class="btn btn-sm"
                                                    style="background:var(--status-free-bg);color:var(--status-free);border:1.5px solid var(--status-free);font-weight:700;">
                                                ✓ Aprovar
                                            </button>
                                        </form>
                                        <form asp-controller="Emprestimos" asp-action="Reprovar" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="emprestimoId" value="@e.Id" />
                                            <button type="submit" class="btn btn-sm"
                                                    style="background:var(--status-busy-bg);color:var(--status-busy);border:1.5px solid var(--status-busy);font-weight:700;">
                                                ✕ Recusar
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="panel mb-4">
        <div class="panel-header">
            <span class="panel-title">Participantes atuais</span>
            @if (participantesAtivos.Any())
            {
                <span class="badge badge-free">@participantesAtivos.Count ativo@(participantesAtivos.Count != 1 ? "s" : "")</span>
            }
        </div>
        @if (!participantesAtivos.Any())
        {
            <div class="py-4 text-center text-muted" style="font-size:.9rem;">
                Nenhum participante com canteiro ativo no momento.
            </div>
        }
        else
        {
            <div class="table-wrapper" style="border-radius:0;border:none;box-shadow:none;">
                <table>
                    <thead>
                        <tr>
                            <th>Participante</th>
                            <th>Canteiro</th>
                            <th style="width:130px;">Desde</th>
                            <th style="width:160px;text-align:center;">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in participantesAtivos)
                        {
                            <tr>
                                <td><strong>@p.Usuario?.Nome</strong></td>
                                <td>@p.Canteiro.Identificacao</td>
                                <td style="font-size:.8rem;color:var(--gray-400);">@p.DataPedido.ToLocalTime().ToString("g")</td>
                                <td class="text-center">
                                    <form asp-controller="Solicitacoes" asp-action="Sair" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="solicitacaoId" value="@p.Id" />
                                        <button type="submit" class="btn btn-sm"
                                                style="background:var(--status-busy-bg);color:var(--status-busy);border:1.5px solid var(--status-busy);font-weight:700;">
                                            ✕ Remover
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}
