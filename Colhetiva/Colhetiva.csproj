    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Colhetiva.Core\Colhetiva.Core.csproj" />
    <ProjectReference Include="..\Colhetiva.Infrastructure\Colhetiva.Infrastructure.csproj" />
  </ItemGroup>

</Project>
